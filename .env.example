# Harbor View environment configuration.
#
# Copy this file to .env (gitignored) and fill in real values, or set
# these as actual environment variables in your deployment. Never
# commit a real API key -- this file is checked in specifically so the
# *names* of the variables are documented without any secret value
# alongside them.
#
# See docs/sprint-004-notes.md for the full writeup of how these are
# used.

# Required for live AIS data (harbor_view.providers.ais.AISProvider).
# Get a free key at https://aisstream.io after creating an account.
# If unset, AISProvider.get_vessels() logs a warning and returns an
# empty vessel list -- it does NOT fall back to placeholder data and
# does NOT raise.
AISSTREAM_API_KEY=

# Optional. Overrides the geographic region AISProvider listens to.
# Format: "lat1,lon1,lat2,lon2" (two opposite corners of a bounding
# box). Defaults to a box around Port Everglades / Fort Lauderdale
# Beach, matching the chart's own geography
# (see harbor_view/chart/geometry.py's REF_LAT/REF_LON).
# HARBOR_VIEW_AIS_BBOX=25.85,-80.30,26.45,-79.85

# Optional. How many seconds AISProvider listens to the live feed
# before returning whatever it collected. AIS is a continuous stream,
# not a request/response API, so get_vessels() has to pick a window.
# Defaults to 12.
# HARBOR_VIEW_AIS_LISTEN_SECONDS=12
